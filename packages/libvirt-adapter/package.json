{
  "name": "wasm-libvirt",
  "version": "0.1.4",
  "description": "TypeScript adapter for libvirt backed by Rust/WASM and virt",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "wasm",
    "README.md"
  ],
  "optionalDependencies": {
    "wasm-libvirt-host-darwin-arm64": "0.1.4",
    "wasm-libvirt-host-linux-arm64": "0.1.4",
    "wasm-libvirt-host-linux-x64": "0.1.4"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "prepublishOnly": "node ../../scripts/release-check.mjs"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT"
}
